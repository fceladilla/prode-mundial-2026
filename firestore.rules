rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function matchData(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data;
    }

    // ---- USERS ----
    // Lectura publica (necesaria para el leaderboard). El usuario crea su propio
    // perfil pero NO puede tocar sus campos de puntaje: eso solo lo hace la
    // logica de servidor (Admin SDK, que ignora estas reglas).
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.totalPoints == 0
        && request.resource.data.exactResults == 0
        && request.resource.data.correctResults == 0;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.totalPoints == resource.data.totalPoints
        && request.resource.data.exactResults == resource.data.exactResults
        && request.resource.data.correctResults == resource.data.correctResults;
    }

    // ---- PREDICTIONS ----
    // Lectura: el dueno siempre; otros usuarios solo cuando el partido ya no
    // esta "upcoming" (empezo o termino). Escritura: solo el dueno, solo
    // mientras el partido siga "upcoming" y antes de su horario de inicio.
    // No puede auto-asignarse puntos. El ID del doc debe ser {uid}_{matchId}:
    // garantiza UN pronostico por usuario por partido (los scripts de scoring
    // evaluan todos los docs del matchId, sin esto se podria cobrar N veces).
    match /predictions/{predId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && matchData(resource.data.matchId).status != 'upcoming';
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && predId == request.auth.uid + '_' + request.resource.data.matchId
        && request.resource.data.predictedHomeGoals >= 0
        && request.resource.data.predictedAwayGoals >= 0
        && request.resource.data.pointsEarned == 0
        && request.resource.data.evaluated == false
        && matchData(request.resource.data.matchId).status == 'upcoming'
        && matchData(request.resource.data.matchId).scheduledAt > request.time;
    }

    // ---- MATCHES ----
    // Lectura para todos. Escritura solo desde el servidor (seed/Admin SDK).
    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    // ---- COMMENTS ----
    // Foro global (matchId == null) y comentarios por partido. Solo usuarios
    // autenticados leen y crean (y solo a su propio nombre). El texto es
    // inmutable; el unico update permitido es dar/quitar "me gusta", que
    // agrega o saca exactamente el uid propio de la lista `likes`.
    // Borrar solo el propio.
    match /comments/{commentId} {
      // Valida que el update solo toque `likes` y que el cambio sea
      // exactamente el uid del que pide (sin tocar likes ajenos).
      function likeToggleOk() {
        let before = resource.data.get('likes', []).toSet();
        let after = request.resource.data.likes.toSet();
        let added = after.difference(before);
        let removed = before.difference(after);
        let self = [request.auth.uid].toSet();
        return (added == self && removed.size() == 0)
            || (removed == self && added.size() == 0);
      }

      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.get('likes', []) == [];
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        && request.resource.data.likes is list
        && likeToggleOk();
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
